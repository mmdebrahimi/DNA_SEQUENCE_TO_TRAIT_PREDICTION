{
  "artifact": "hiv_epistasis_vs_additive",
  "schema": "hiv-epistasis-v1",
  "question": "Does a constrained pairwise-interaction model beat the additive mutation-presence baseline out-of-sample on Stanford HIVDB PhenoSense fold-change?",
